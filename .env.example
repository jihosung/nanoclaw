# Time zone used by the host process for scheduling and timestamps.
TZ=

# Local OneCLI gateway URL used to inject credentials into agent requests.
ONECLI_URL=

# Discord bot token for the NanoClaw Discord channel integration.
DISCORD_BOT_TOKEN=

# Default model name used when launching agent runs.
AGENT_MODEL=

# Enable the optional translation helper for inbound or outbound text handling.
TRANSLATOR_ENABLED=

# Base URL for the translation service when translation is enabled.
TRANSLATOR_URL=

# Model name served by the translation backend.
TRANSLATOR_MODEL=

# Discord user ID to mention when posting result notifications.
RESULT_MENTION_DISCORD_USER_ID=

# Display text used alongside result mentions in Discord messages.
RESULT_MENTION_DISPLAY_TEXT=

# Optional: command used when restart_host is requested (main group only).
# Examples:
# Linux(systemd): systemctl --user restart nanoclaw
# macOS(launchd): launchctl kickstart -k gui/$(id -u)/com.nanoclaw
NANOCLAW_RESTART_CMD=

# Maximum runtime for a single agent container task, in milliseconds.
CONTAINER_TIMEOUT=

# Idle timeout before a running session is considered inactive, in milliseconds.
IDLE_TIMEOUT=
